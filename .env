# Optional: Enable dry-run mode (no actual PRs will be created)
# Set to "true" for testing without making changes
DRY_RUN=false

# Optional: Kubernetes Configuration
# Leave empty to use default kubeconfig location (~/.kube/config)
KUBECONFIG=

# Optional: Namespaces to monitor (space-separated)
# Default: default kube-system
NAMESPACES=default

# Optional: Number of log lines to tail per pod
# Default: 50
TAIL_LINES=50

# Optional: Check interval in seconds
# Default: 300 (5 minutes)
CHECK_INTERVAL_SECONDS=300
